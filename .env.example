# Copy to .env.local for local dev, and set these in Vercel project settings.

# --- Vercel KV (Upstash) ---------------------------------------------------
# Created automatically when you add a KV store to the project in Vercel.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Admin token (optional) ------------------------------------------------
# If set, admin writes must include this token (the admin page prompts for it
# and stores it in your browser). Leave blank to rely on the unlisted route only.
ADMIN_TOKEN=
